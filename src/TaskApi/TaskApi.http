@TaskApi_HostAddress = http://localhost:5242

# List all tasks
GET {{TaskApi_HostAddress}}/api/tasks
Accept: application/json

###

# Get task by id
GET {{TaskApi_HostAddress}}/api/tasks/1
Accept: application/json

###

# Create a new task
POST {{TaskApi_HostAddress}}/api/tasks
Content-Type: application/json

{
	"title": "Nueva tarea",
	"description": "Descripción opcional",
	"isCompleted": false
}

###

# Update an existing task
PUT {{TaskApi_HostAddress}}/api/tasks/1
Content-Type: application/json

{
	"title": "Tarea actualizada",
	"description": "Actualizada",
	"isCompleted": true
}

###

# Delete a task
DELETE {{TaskApi_HostAddress}}/api/tasks/1

###
